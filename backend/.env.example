# SERV.O - Environment Configuration Template
# Copy this file to backend/.env and fill in values

# PostgreSQL Database
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=servo
PG_USER=servo_user
PG_PASSWORD=servo_pwd

# Application
DB_TYPE=postgresql
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs

# JWT (auto-generated if not set)
# JWT_SECRET=your_jwt_secret_here
